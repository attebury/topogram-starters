{
  "version": "0.1",
  "workspace": "./topo",
  "outputs": {
    "app": {
      "path": "./app",
      "ownership": "generated"
    }
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_sqlite",
        "surface": "proj_db_sqlite",
        "generator": {
          "id": "@topogram/generator-sqlite-db",
          "version": "1",
          "package": "@topogram/generator-sqlite-db"
        },
        "kind": "database"
      }
    ]
  }
}
