{
  "version": "0.1",
  "workspace": "./topo",
  "outputs": {
    "app": {
      "path": "./app",
      "ownership": "generated"
    }
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "projection": "proj_api",
        "generator": {
          "id": "@topogram/generator-express-api",
          "version": "1",
          "package": "@topogram/generator-express-api"
        },
        "port": 3000,
        "kind": "api_service"
      },
      {
        "id": "app_react",
        "projection": "proj_web_surface",
        "generator": {
          "id": "@topogram/generator-react-web",
          "version": "1",
          "package": "@topogram/generator-react-web"
        },
        "port": 5173,
        "kind": "web_surface",
        "uses_api": "app_api"
      }
    ]
  },
  "implementation": {
    "id": "web-api-template",
    "module": "./implementation/index.js",
    "export": "WEB_API_IMPLEMENTATION"
  }
}
